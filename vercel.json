{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "gekuendigt-abfindung.de" }],
      "destination": "https://www.gekuendigt-abfindung.de/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/revalidate?secret=${REVALIDATE_SECRET}",
      "schedule": "0 6 * * 1"
    }
  ]
}
